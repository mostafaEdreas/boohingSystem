{
	"info": {
		"_postman_id": "booking-system-api",
		"name": "Booking System API",
		"description": "Backend API: hotels, rooms, search availability.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost"
		},
		{
			"key": "token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/login",
							"host": ["{{base_url}}"],
							"path": ["api", "login"]
						},
						"description": "POST /api/login - Returns user and token. Use the token in Authorization: Bearer {{token}} for protected routes."
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/logout",
							"host": ["{{base_url}}"],
							"path": ["api", "logout"]
						},
						"description": "POST /api/logout - Revokes current token. Requires Bearer token."
					}
				}
			]
		},
		{
			"name": "Hotels",
			"item": [
				{
					"name": "Create Hotel",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Grand Hotel\",\n    \"city\": \"Cairo\",\n    \"country\": \"Egypt\",\n    \"rating\": 4\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/hotels",
							"host": ["{{base_url}}"],
							"path": ["api", "hotels"]
						},
						"description": "POST /api/hotels - Create a new hotel."
					}
				},
				{
					"name": "List Hotels",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/hotels?city=&rating=&per_page=10",
							"host": ["{{base_url}}"],
							"path": ["api", "hotels"],
							"query": [
								{"key": "city", "value": "", "description": "Filter by city"},
								{"key": "rating", "value": "", "description": "Filter by rating (0-5)"},
								{"key": "per_page", "value": "10", "description": "Pagination size"}
							]
						},
						"description": "GET /api/hotels - List hotels with optional filters (city, rating) and pagination."
					}
				}
			]
		},
		{
			"name": "Rooms",
			"item": [
				{
					"name": "Create Room",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"hotel_id\": 1,\n    \"name\": \"Double Room\",\n    \"price_per_night\": 150.00,\n    \"max_occupancy\": 2,\n    \"available_rooms\": 5,\n    \"rooms_count\": 5\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/rooms",
							"host": ["{{base_url}}"],
							"path": ["api", "rooms"]
						},
						"description": "POST /api/rooms - Create a new room. hotel_id must exist."
					}
				}
			]
		},
		{
			"name": "Search",
			"item": [
				{
					"name": "Search Availability",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/search?city=Cairo&checkin_date=2025-03-15&checkout_date=2025-03-18&guests=2",
							"host": ["{{base_url}}"],
							"path": ["api", "search"],
							"query": [
								{"key": "city", "value": "Cairo", "description": "City to search"},
								{"key": "checkin_date", "value": "2025-03-15", "description": "Check-in date (Y-m-d)"},
								{"key": "checkout_date", "value": "2025-03-18", "description": "Check-out date (Y-m-d), must be after checkin"},
								{"key": "guests", "value": "2", "description": "Number of guests (min 1)"}
							]
						},
						"description": "GET /api/search - Returns hotels with available rooms and total_price (price × nights) per room."
					}
				}
			]
		}
	]
}
